{
  "name": "cyberchef-playground",
  "version": "2.0.0",
  "description": "CTF-style challenge platform for learning cryptography and reverse engineering using CyberChef",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "sync": "node sync.js",
    "docker:build": "docker build -t cyberchef-playground:latest .",
    "docker:run": "docker run -p 3000:3000 cyberchef-playground:latest",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f"
  },
  "keywords": [
    "cyberchef",
    "ctf",
    "cryptography",
    "reverse-engineering",
    "blue-team",
    "security",
    "education",
    "training"
  ],
  "author": "CyberChef Playground",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "cyberchef-node": "^2.0.3",
    "express": "^4.18.2"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/ChickenLoner/cyberchef-playground"
  },
  "bugs": {
    "url": "https://github.com/ChickenLoner/cyberchef-playground/issues"
  },
  "homepage": "https://github.com/ChickenLoner/cyberchef-playground#readme"
}